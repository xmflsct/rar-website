    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@headlessui/react": "^2.2.10",
    "@myparcel/constants": "^2.6.0",
    "@myparcel/sdk": "^4.4.2",
    "@react-router/cloudflare": "^8.0.1",
    "@sentry/react": "^10.62.0",
    "classnames": "^2.5.1",
    "date-fns": "^4.4.0",
    "graphql": "^16.14.2",
