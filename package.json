    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "stripe": "^22.3.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
